{
  "name": "react-joyride",
  "version": "2.9.3",
  "description": "Create guided tours for your apps",
  "author": "Gil Barbara <gilbarbara@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilbarbara/react-joyride.git"
  },
  "bugs": {
    "url": "https://github.com/gilbarbara/react-joyride/issues"
  },
  "homepage": "https://react-joyride.com/",
  "keywords": [
    "react",
    "react-component",
    "tooltips",
    "joyride",
    "walkthroughs",
    "tour"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "peerDependencies": {
    "react": "16.8 - 19",
    "react-dom": "16.8 - 19"
  },
  "dependencies": {
    "@fastify/deepmerge": "^3.2.0",
    "@floating-ui/react-dom": "^2.1.7",
    "@gilbarbara/deep-equal": "^0.4.1",
    "@gilbarbara/hooks": "^0.11.0",
    "@gilbarbara/types": "^0.2.2",
    "is-lite": "^2.0.0",
    "react-innertext": "^1.1.5",
    "scroll": "^3.0.1",
    "scrollparent": "^2.1.0",
    "tree-changes-hook": "^0.11.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@gilbarbara/eslint-config": "^1.0.4",
    "@gilbarbara/node-helpers": "^0.1.0",
    "@gilbarbara/prettier-config": "^1.0.0",
    "@gilbarbara/tsconfig": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-big-lib": "^12.0.0",
    "@swc/core": "^1.15.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/shoehorn": "^0.1.2",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/scroll": "^3.0.3",
    "@types/scrollparent": "^2.0.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "caniuse-lite": "^1.0.30001770",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest-extended": "^7.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "repo-tools": "^0.3.1",
    "size-limit": "^12.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "pnpm clean && tsup && ts-node scripts/fix-cjs.ts",
    "watch": "tsup --watch",
    "clean": "del dist/*",
    "demo": "pnpm --dir demo dev",
    "lint": "eslint --fix src test",
    "typecheck": "tsc -p test/tsconfig.json",
    "typevalidation": "attw -P",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "e2e": "playwright test",
    "e2e:chromium": "pnpm e2e --project=chromium",
    "e2e:debug": "pnpm e2e --project=chromium --debug",
    "e2e:ui": "pnpm e2e --ui",
    "e2e:headed": "pnpm e2e --headed",
    "e2e:report": "playwright show-report",
    "format": "prettier \"**/*.{js,jsx,ts,tsx}\" --write",
    "validate": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm e2e && pnpm build && pnpm size && pnpm typevalidation",
    "size": "size-limit",
    "prepare": "husky"
  },
  "tsup": {
    "dts": true,
    "entry": [
      "src/index.tsx"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "target": "es2018",
    "sourcemap": true,
    "splitting": false
  },
  "prettier": "@gilbarbara/prettier-config",
  "size-limit": [
    {
      "name": "commonjs",
      "path": "./dist/index.js",
      "limit": "30 kB"
    },
    {
      "name": "esm",
      "path": "./dist/index.mjs",
      "limit": "30 kB",
      "import": "*"
    }
  ]
}
