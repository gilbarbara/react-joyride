exports[`Overlay > should not render Spotlight for center placement 1`] = `
<div
  aria-hidden="true"
  class="react-joyride__overlay"
  data-testid="overlay"
  style="height: 50px; pointer-events: none; bottom: 0px; left: 0px; overflow: hidden; position: absolute; right: 0px; top: 0px; z-index: 100;"
>
  <svg
    class="react-joyride__spotlight"
    data-testid="spotlight"
    style="height: 50px; left: 0px; position: absolute; top: 0px; width: 1024px;"
  >
    <path
      d="M0 0H1024V50H0Z"
      fill="#00000080"
      fill-rule="evenodd"
      style="cursor: pointer; pointer-events: auto;"
    />
  </svg>
</div>
`;

