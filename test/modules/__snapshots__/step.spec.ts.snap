      "marginTop": 15,
    },
    "tooltipFooterSpacer": {
      "flex": 1,
    },
    "tooltipTitle": {
      "fontSize": 18,
      "margin": 0,
    },
  },
  "target": ".test-target",
  "targetWaitTimeout": 1000,
}
