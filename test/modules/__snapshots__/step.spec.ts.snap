      "right": 0,
      "top": 0,
      "zIndex": 100,
    },
    "spotlight": {
      "backgroundColor": "gray",
      "borderRadius": 4,
      "position": "absolute",
    },
    "tooltip": {
      "backgroundColor": "#fff",
      "borderRadius": 5,
      "boxSizing": "border-box",
      "color": "#333",
      "fontSize": 16,
      "maxWidth": "100%",
      "padding": 15,
      "position": "relative",
      "width": 380,
    },
    "tooltipContainer": {
      "lineHeight": 1.4,
      "textAlign": "center",
    },
    "tooltipContent": {
      "padding": "20px 10px",
    },
