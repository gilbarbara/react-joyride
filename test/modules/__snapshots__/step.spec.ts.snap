      "padding": 8,
    },
    "buttonClose": {
      "WebkitAppearance": "none",
      "backgroundColor": "transparent",
      "border": 0,
      "borderRadius": 0,
      "color": "#333",
      "cursor": "pointer",
      "fontSize": 16,
      "height": 14,
      "lineHeight": 1,
      "padding": 15,
      "position": "absolute",
      "right": 0,
      "top": 0,
      "width": 14,
    },
    "buttonNext": {
      "WebkitAppearance": "none",
      "backgroundColor": "#f04",
      "border": 0,
      "borderRadius": 4,
      "color": "#fff",
      "cursor": "pointer",
      "fontSize": 16,
      "lineHeight": 1,
      "padding": 8,
    },
    "buttonSkip": {
      "WebkitAppearance": "none",
      "backgroundColor": "transparent",
      "border": 0,
      "borderRadius": 0,
      "color": "#333",
      "cursor": "pointer",
      "fontSize": 14,
      "lineHeight": 1,
      "padding": 8,
    },
    "floater": {
      "display": "inline-block",
      "filter": "drop-shadow(0 0 3px rgba(0, 0, 0, 0.3))",
      "maxWidth": "100%",
      "transition": "opacity 0.3s",
    },
    "options": {
      "arrowColor": "#fff",
      "arrowSpacing": 5,
      "backgroundColor": "#fff",
      "beaconSize": 36,
      "overlayColor": "rgba(0, 0, 0, 0.5)",
      "primaryColor": "#f04",
      "textColor": "#333",
      "width": 380,
      "zIndex": 100,
    },
    "overlay": {
      "backgroundColor": "rgba(0, 0, 0, 0.5)",
      "bottom": 0,
      "left": 0,
      "mixBlendMode": "hard-light",
      "overflow": "hidden",
