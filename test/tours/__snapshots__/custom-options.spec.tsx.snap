exports[`Joyride > Custom Options > should render STEP 1 Tooltip with custom styles > tooltip 1`] = `
<div
  class="react-joyride__floater"
  data-testid="floater"
  id="react-joyride-step-0"
  style="left: 0px; position: absolute; top: 0px; z-index: 200; display: inline-block; filter: drop-shadow(0 0 3px rgba(0, 0, 0, 0.3)); max-width: 100%; opacity: 1; transition: opacity 0.3s; transform: translate(5px, 36px);"
>
  <div
    aria-describedby="joyride-tooltip-content"
    aria-label="The first step of many! Keep walking!"
    aria-modal="true"
    class="react-joyride__tooltip"
    data-joyride-step="0"
    role="alertdialog"
    style="background-color: rgb(255, 255, 255); box-sizing: border-box; color: rgb(51, 51, 51); font-size: 16px; max-width: 100%; position: relative; width: 380px; border-radius: 8px; padding: 12px;"
  >
    <div
      style="line-height: 1.4; text-align: center;"
    >
      <div
        id="joyride-tooltip-content"
        style="padding: 1px 8px;"
      >
        The first step of many! Keep walking!
      </div>
    </div>
    <div
      style="align-items: center; display: flex; justify-content: flex-end; margin-top: 15px;"
    >
      <div
        style="flex: 1 1 0%;"
      >
        <button
          aria-label="Skip"
          aria-live="off"
          data-action="skip"
          data-testid="button-skip"
          role="button"
          style="background-color: transparent; border: 0px; border-radius: 0px; color: rgb(51, 51, 51); cursor: pointer; font-size: 14px; line-height: 1; -webkit-appearance: none; padding: 8px;"
          title="Skip"
          type="button"
        >
          Skip
        </button>
      </div>
      <button
        aria-label="Next"
        data-action="primary"
        data-testid="button-primary"
        role="button"
        style="border: 0px; border-radius: 4px; color: rgb(255, 255, 255); cursor: pointer; font-size: 16px; line-height: 1; -webkit-appearance: none; padding: 8px; background-color: rgb(169, 71, 255);"
        title="Next"
        type="button"
      >
        Next
      </button>
    </div>
    <button
      aria-label="Close"
      data-action="close"
      data-testid="button-close"
      role="button"
      style="background-color: transparent; border: 0px; border-radius: 0px; cursor: pointer; font-size: 16px; line-height: 1; -webkit-appearance: none; padding: 15px; position: absolute; right: 0px; top: 0px;"
      title="Close"
      type="button"
    >
      <svg
