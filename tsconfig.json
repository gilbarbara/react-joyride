{
  "extends": "@gilbarbara/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "downlevelIteration": true,
    "noEmit": true,
    "paths": {
      "~/*": ["src/*"],
      "~/test-utils": ["test/__setup__/test-utils.ts"]
    },
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*"]
}
